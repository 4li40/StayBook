# Neon Postgres connection string (or any PostgreSQL database URL).
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Random string, 32+ characters. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-32-plus-character-random-string

# Public URL where the API server is reachable.
BETTER_AUTH_URL=http://localhost:3000

# Public URL where the web app is reachable (CORS allow-list origin).
CORS_ORIGIN=http://localhost:3001

# Optional. Defaults to "development".
# NODE_ENV=development
